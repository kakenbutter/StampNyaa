{
  "name": "stampnyaa",
  "productName": "StampNyaa",
  "version": "1.6.0",
  "description": "A simple app for using LINE stickers in your favorite messaging applications.",
  "repository": {
    "type": "git",
    "url": "https://github.com/MarvNC/StampNyaa"
  },
  "main": "dist/index.js",
  "scripts": {
    "start": "yarn build && electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepare": "husky"
  },
  "keywords": [],
  "author": {
    "name": "MarvNC",
    "email": "rotrobmin@gmail.com"
  },
  "license": "GPL-3.0",
  "dependencies": {
    "@nut-tree-fork/nut-js": "^4.2.6",
    "@shopify/draggable": "^1.2.1",
    "axios": "^1.18.1",
    "electron-squirrel-startup": "^1.0.1",
    "electron-store": "^11.0.2",
    "jimp": "^1.6.1",
    "jsdom": "^29.1.1",
    "sqlite3": "^6.0.1",
    "update-electron-app": "^3.3.0"
  },
  "optionalDependencies": {
    "electron-clipboard-ex": "^1.3.3"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
    "@electron-forge/publisher-github": "^7.11.2",
    "@eslint/js": "^10.0.1",
    "@types/jsdom": "^28.0.3",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "electronmon": "^2.0.4",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0"
  },
  "lint-staged": {
    "*.{js,ts}": "prettier --write"
  }
